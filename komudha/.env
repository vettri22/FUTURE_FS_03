# ============================================================
# KOMUDHA Boutique — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=komudha123
DB_NAME=komudha_boutique

# Razorpay (get from razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Fast2SMS (get from fast2sms.com — for OTP)
SMS_API_KEY=your_api_key

# Admin
ADMIN_MOBILE=9876543210
WHATSAPP_NUMBER=919876543210

# Set to False in production to use real SMS
DEV_MODE_OTP=False
